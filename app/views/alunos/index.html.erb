<p style="color: green"><%= notice %></p>

<% content_for :title, "Alunos" %>

<h1>Alunos</h1>

<div id="alunos">
  <% @alunos.each do |aluno| %>
    <%= render aluno %>
    <p>
      <%= link_to "Show this aluno", aluno %>
    </p>
  <% end %>
</div>

<%= paginate @alunos %>

<%= link_to "New aluno", new_aluno_path %>

<%= link_to "Gerar PDF", alunos_path(format: :pdf), class: "btn btn-primary" %>
